{
  "manifest_version": 3,
  "name": "LearnSync",
  "version": "1.0.0",
  "description": "Turn Video Learning Into Structured Knowledge — Timestamp-based notes for YouTube.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LearnSync"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
